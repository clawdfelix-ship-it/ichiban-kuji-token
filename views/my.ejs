<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <meta name="description" content="本平台提供台灣一番賞代購、代抽、代收與跨境轉送服務，所有抽選行為於台灣完成，香港地區僅提供商品領取與寄送。">
  <title>我的商品 - 台灣一番賞委託代抽 [TOKEN VERSION]</title>
  <link rel="stylesheet" href="/css/style.css?v=token-1">
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="site-logo">
        <img src="/img/mirai-3.png" alt="TMA台灣分部-未來飛翔">
      </a>
      <a href="/" class="back-link">← 返回首頁</a>
      <h1>我的商品記錄</h1>
    </div>
  </header>

  <main class="container">
    <div id="loginRequired" class="empty-state hidden">
      <p>請先登入會員才能查看你的商品記錄</p>
      <a href="/login" class="btn btn-primary">立即登入</a>
    </div>

    <div id="myContent" class="hidden">
      <section class="user-section">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
          <h2 style="margin: 0;">我的獲得商品</h2>
          <a href="/logout" class="btn btn-secondary">登出</a>
        </div>

        <div class="entry-section" style="margin-bottom: 16px;">
          <h3 style="margin-top: 0;">我的 Tokens</h3>
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <div class="stat-badge">
              <strong>餘額</strong>: <span id="tokenBalance">--</span> tokens
            </div>
            <button class="btn btn-primary btn-sm" data-topup-tokens="299">充值 299</button>
            <button class="btn btn-primary btn-sm" data-topup-tokens="598">充值 598</button>
            <button class="btn btn-primary btn-sm" data-topup-tokens="897">充值 897</button>
          </div>
          <div id="topupHint" style="margin-top: 10px; color: var(--text-tertiary); font-size: 13px;"></div>
        </div>

        <div id="entriesList" class="user-winnings">
          <!-- loaded by JS -->
        </div>
      </section>
    </div>
  </main>

  <footer>
    <div class="container">
      <div class="legal-footer" style="background: #f8f9fa; border-radius: 8px; padding: 16px; margin-bottom: 16px; text-align: left; font-size: 13px; line-height: 1.6; color: #495057;">
        <strong>【服務聲明】</strong><br>
        <ol style="margin: 8px 0 0 20px; padding: 0;">
          <li>本平台僅提供日本／台灣一番賞商品之代購及代抽服務。</li>
          <li>所有抽選行為及相關交易均於海外（台灣）由當地合作單位完成，香港僅作為資訊展示及代購安排之平台，不涉及任何抽獎、博彩或機會遊戲活動之經營或操作。</li>
          <li>由於相關抽選活動並非於香港進行，本平台並不構成香港法例下之獎券、抽獎或賭博業務。</li>
          <li>用戶於下單時，即表示已年滿18歲，明白及同意抽選行為於海外進行，接受抽選結果之隨機性及不可預測性。</li>
          <li>所有商品內容、款式及中獎機率，均以當地官方公佈為準。基於抽選性質，所有訂單一經確認恕不接受退款或更換。</li>
        </ol>
      </div>
      <p>&copy; <%= new Date().getFullYear() %> Ichiban Kuji Proxy Service</p>
      <p style="margin-top: 8px; opacity: 0.7;">Powered by TMA台灣分部-未來飛翔</p>
    </div>
  </footer>

  <script src="/js/app.js?v=token-1"></script>
  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      document.getElementById('loginRequired').classList.add('hidden');
      document.getElementById('myContent').classList.remove('hidden');

      try {
        const params = new URLSearchParams(window.location.search);
        const topup = params.get('topup');
        const hintEl = document.getElementById('topupHint');
        if (topup === 'success') {
          hintEl.textContent = '付款完成，Tokens 會喺幾秒內自動入帳。';
        } else if (topup === 'cancel') {
          hintEl.textContent = '已取消付款。';
        }

        const balance = await apiRequest('/api/wallet/balance');
        document.getElementById('tokenBalance').textContent = balance.token_balance ?? 0;
        document.querySelectorAll('[data-topup-tokens]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            btn.disabled = true;
            try {
              const tokens = parseInt(btn.dataset.topupTokens, 10);
              const r = await apiRequest('/api/wallet/stripe/checkout', {
                method: 'POST',
                body: JSON.stringify({ tokens })
              });
              window.location.href = r.url;
            } catch (e) {
              btn.disabled = false;
              alert('充值失敗: ' + e.message);
            }
          });
        });

        const result = await apiRequest('/api/my/entries');
        const entries = result.entries;

        const listEl = document.getElementById('entriesList');
        if (entries.length === 0) {
          listEl.innerHTML = '<div class="empty-state"><p>你暫時未有代抽記錄</p></div>';
          return;
        }

        let html = '';
        entries.forEach(entry => {
          const redeemedClass = entry.redeemed_at ? 'redeemed' : '';
          const redeemedText = entry.redeemed_at ? '已兌換' : '未兌換';
          const buttonText = entry.redeemed_at ? '已核銷' : '兌換核銷';
          html += `
            <div class="winning-card ${entry.prize_is_final ? 'final' : ''} ${redeemedClass}">
              <div class="my-entry-header">
                <strong>${entry.raffle_title}</strong>
                <span class="date">${new Date(entry.drawn_at).toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' })} · ${redeemedText}</span>
              </div>
              <div class="my-entry-prize">
                ${entry.prize_tier ? `<span class="tier-badge ${entry.prize_tier.toLowerCase()}">${entry.prize_tier}</span>` : ''}
                ${entry.prize_is_final ? '<span class="final-badge">最終賞</span>' : ''}
                <strong>${entry.prize_name}</strong>
              </div>
              <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
                <div>
                  <small style="color: #64748b;">驗證碼:</small>
                  <code style="display: inline-block; margin-left: 4px; background: #f5f5f5; padding: 2px 6px; border-radius: 4px; font-family: monospace;">${entry.verification_code}</code>
                </div>
                <button class="btn btn-sm ${entry.redeemed_at ? 'btn-secondary disabled' : 'btn-primary'}" 
                        onclick="redeemItem(${entry.id})" 
                        ${entry.redeemed_at ? 'disabled' : ''}>
                  ${buttonText}
                </button>
              </div>
            </div>
          `;
        });

        listEl.innerHTML = html;
      } catch (err) {
        if (err.message.includes('需要登入')) {
          document.getElementById('myContent').classList.add('hidden');
          document.getElementById('loginRequired').classList.remove('hidden');
          return;
        }
        alert('獲取代抽記錄失敗: ' + err.message);
      }
    });

    // Redeem item function
    async function redeemItem(entryId) {
      if (!confirm('確認要核銷這個商品嗎？')) {
        return;
      }
      try {
        const result = await apiRequest(`/api/my/entries/${entryId}/redeem`, {
          method: 'POST'
        });
        if (result.success) {
          alert('核銷成功！');
          location.reload();
        } else {
          alert('核銷失敗: ' + (result.error || '未知錯誤'));
        }
      } catch (err) {
        alert('核銷失敗: ' + err.message);
      }
    }
  </script>
</body>
</html>

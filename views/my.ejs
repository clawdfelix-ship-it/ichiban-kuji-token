<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>我的抽獎記錄 - 一番賞線上抽獎</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="back-link">← 返回首頁</a>
      <h1>我的抽獎記錄</h1>
    </div>
  </header>

  <main class="container">
    <div id="loginRequired" class="empty-state">
      <p>請先登入會員才能查看你的抽獎記錄</p>
      <a href="/login" class="btn btn-primary">立即登入</a>
    </div>

    <div id="myContent" class="hidden">
      <section class="user-section">
        <h2>我的中獎記錄</h2>
        <div id="entriesList" class="user-winnings">
          <!-- loaded by JS -->
        </div>
      </section>
    </div>
  </main>

  <footer>
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> Ichiban Kuji Raffle System</p>
    </div>
  </footer>

  <script src="/js/app.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      console.log('=== Ichiban Kuji - My Page Load ===');
      
      // Get userId from URL query (fallback) or localStorage
      let userId = null;
      
      // Try URL first - this works even if localStorage is blocked
      const urlParams = new URLSearchParams(window.location.search);
      userId = urlParams.get('userId');
      
      // If no userId in URL, try localStorage
      if (!userId) {
        const userJson = localStorage.getItem('ikr_user');
        if (userJson) {
          try {
            const user = JSON.parse(userJson);
            userId = user.id;
            console.log('Got userId from localStorage:', userId);
          } catch (e) {
            console.error('Invalid user in localStorage', e);
            localStorage.removeItem('ikr_user');
          }
        }
      } else {
        console.log('Got userId from URL:', userId);
      }

      if (!userId) {
        console.log('No userId found, show login required');
        document.getElementById('loginRequired').classList.remove('hidden');
        return;
      }

      document.getElementById('myContent').classList.remove('hidden');

      try {
        const url = `/api/my/entries?userId=${userId}`;
        console.log('Fetching entries from:', url);
        
        const result = await apiRequest(url);
        console.log('API response:', result);
        const entries = result.entries;
        console.log('Got entries:', entries);

        const listEl = document.getElementById('entriesList');
        if (entries.length === 0) {
          listEl.innerHTML = '<div class="empty-state"><p>你暫時未有抽獎記錄</p></div>';
          return;
        }

        let html = '';
        entries.forEach(entry => {
          html += `
            <div class="winning-card ${entry.prize_is_final ? 'final' : ''}">
              <div class="my-entry-header">
                <strong>${entry.raffle_title}</strong>
                <span class="date">${new Date(entry.drawn_at).toLocaleString('zh-HK')}</span>
              </div>
              <div class="my-entry-prize">
                ${entry.prize_tier ? `<span class="tier-badge ${entry.prize_tier.toLowerCase()}">${entry.prize_tier}</span>` : ''}
                ${entry.prize_is_final ? '<span class="final-badge">最終賞</span>' : ''}
                <strong>${entry.prize_name}</strong>
              </div>
            </div>
          `;
        });

        listEl.innerHTML = html;
      } catch (err) {
        console.error('Failed to load entries', err);
        alert('獲取抽獎記錄失敗: ' + err.message);
      }
    });
  </script>
</body>
</html>

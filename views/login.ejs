<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title><%= (typeof adminMode !== 'undefined' && adminMode) ? '管理員登入' : '會員登入' %> - 一番賞線上抽獎</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="site-logo">
        <img src="/img/mirai-3.png" alt="TMA台灣分部-未來飛翔">
      </a>
      <a href="/" class="back-link">← 返回首頁</a>
      <h1><%= (typeof adminMode !== 'undefined' && adminMode) ? '管理員登入' : '會員登入' %></h1>
    </div>
  </header>

  <main class="container">
    <div class="auth-form">
      <form id="loginForm">
        <input type="hidden" id="adminModeFlag" value="<%= (typeof adminMode !== 'undefined' && adminMode) ? '1' : '0' %>">
        <div class="form-group">
          <label for="username">用戶名</label>
          <input type="text" id="username" name="username" required placeholder="輸入用戶名">
        </div>
        <div class="form-group">
          <label for="password">密碼</label>
          <input type="password" id="password" name="password" required placeholder="輸入密碼">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-large">登入</button>
        </div>
        <% if (!(typeof adminMode !== 'undefined' && adminMode)) { %>
          <p class="auth-footer">
            未有帳號？<a href="/register">立即註冊</a>
          </p>
        <% } %>
      </form>
    </div>
  </main>

  <footer>
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> Ichiban Kuji Raffle System</p>
      <p style="margin-top: 8px; opacity: 0.7;">Powered by TMA台灣分部-未來飛翔</p>
    </div>
  </footer>

  <script src="/js/app.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const username = document.getElementById('username').value.trim();
        const password = document.getElementById('password').value;
        
        try {
          const result = await apiRequest('/api/auth/login', {
            method: 'POST',
            body: JSON.stringify({ username, password })
          });
          
          alert('登入成功！');
          const isAdminMode = document.getElementById('adminModeFlag').value === '1';
          if (isAdminMode && !result.user.is_admin) {
            alert('此帳號不是管理員');
            return;
          }
          window.location.href = isAdminMode ? '/admin' : '/my';
        } catch (err) {
          alert(err.message);
        }
      });
    });
  </script>
</body>
</html>

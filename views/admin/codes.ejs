<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <meta name="description" content="本平台提供台灣一番賞代購、代抽、代收與跨境轉送服務，所有抽選行為於台灣完成，香港地區僅提供商品領取與寄送。">
  <title>驗證碼管理 - <%= title %> - 台灣一番賞委託代抽</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="container">
      <div class="header-content">
        <a href="/" class="site-logo">
          <img src="/img/mirai-3.png" alt="TMA台灣分部-未來飛翔">
        </a>
        <div class="header-text">
          <a href="/admin" class="back-link">← 返回後台</a>
          <h1>驗證碼管理</h1>
          <p><%= title %></p>
        </div>
        <div class="header-buttons">
          <a href="/logout" class="btn btn-secondary btn-sm">登出</a>
        </div>
      </div>
    </div>
  </header>

  <main class="container">
    <input type="hidden" id="raffleId" value="<%= raffleId %>">
    <section class="card">
      <h2>生成新驗證碼</h2>
      <div class="form-row">
        <div class="form-group">
          <label for="generateCount">生成數量</label>
          <input type="number" id="generateCount" min="1" max="5000" value="1">
        </div>
        <button id="generateBtn" class="btn btn-primary">生成</button>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label for="assignUsername">分配會員用戶名 (可選)</label>
        <input type="text" id="assignUsername" placeholder="例如：felix123">
        <small>如填寫，該批驗證碼只可由此會員登入後使用。</small>
      </div>
      <p style="opacity:0.7;margin-top:8px;">提示：生成後可以用「複製全部」一次過拎走。</p>
    </section>

    <section class="card" style="margin-top:16px;">
      <div class="admin-header">
        <h2>已生成驗證碼 (<span id="codesCount">0</span>)</h2>
        <button id="copyAllBtn" class="btn btn-secondary btn-sm" disabled>複製全部</button>
      </div>
      <div id="codesList" class="codes-list">
        <div class="empty-state">
          <p>尚未生成任何驗證碼</p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="legal-footer" style="background: #f8f9fa; border-radius: 8px; padding: 16px; margin-bottom: 16px; text-align: left; font-size: 13px; line-height: 1.6; color: #495057;">
        <strong>【服務聲明】</strong><br>
        <ol style="margin: 8px 0 0 20px; padding: 0;">
          <li>本平台僅提供日本／台灣一番賞商品之代購及代抽服務。</li>
          <li>所有抽選行為及相關交易均於海外（台灣）由當地合作單位完成，香港僅作為資訊展示及代購安排之平台，不涉及任何抽獎、博彩或機會遊戲活動之經營或操作。</li>
          <li>由於相關抽選活動並非於香港進行，本平台並不構成香港法例下之獎券、抽獎或賭博業務。</li>
          <li>用戶於下單時，即表示已年滿18歲，明白及同意抽選行為於海外進行，接受抽選結果之隨機性及不可預測性。</li>
          <li>所有商品內容、款式及中獎機率，均以當地官方公佈為準。基於抽選性質，所有訂單一經確認恕不接受退款或更換。</li>
        </ol>
      </div>
      <p>&copy; <%= new Date().getFullYear() %> Ichiban Kuji Proxy Service</p>
      <p style="margin-top: 8px; opacity: 0.7;">Powered by TMA台灣分部-未來飛翔</p>
    </div>
  </footer>

  <script src="/js/app.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const raffleId = parseInt(document.getElementById('raffleId').value, 10);
      const codesList = document.getElementById('codesList');
      const codesCount = document.getElementById('codesCount');
      const copyAllBtn = document.getElementById('copyAllBtn');
      const generateBtn = document.getElementById('generateBtn');

      async function loadCodes() {
        const result = await apiRequest(`/api/admin/raffles/${raffleId}/codes`);
        const codes = result.codes || [];
        codesCount.textContent = String(codes.length);

        if (codes.length === 0) {
          copyAllBtn.disabled = true;
          codesList.innerHTML = '<div class="empty-state"><p>尚未生成任何驗證碼</p></div>';
          return;
        }

        copyAllBtn.disabled = false;

        let html = '<div class="codes-table-wrapper"><table class="codes-table"><thead><tr><th>驗證碼</th><th>分配會員</th><th>使用會員</th><th>狀態</th><th>生成時間</th></tr></thead><tbody>';
        codes.forEach(c => {
          const status = c.used ? '已使用' : '未使用';
          const statusClass = c.used ? 'used' : 'unused';
          html += `
            <tr>
              <td><code class="code-text">${c.code}</code></td>
              <td>${c.assigned_username || '-'}</td>
              <td>${c.used_username || '-'}</td>
              <td><span class="status-badge ${statusClass}">${status}</span></td>
              <td>${new Date(c.created_at).toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' })}</td>
            </tr>
          `;
        });
        html += '</tbody></table></div>';
        codesList.innerHTML = html;
      }

      generateBtn.addEventListener('click', async () => {
        const count = parseInt(document.getElementById('generateCount').value, 10);
        const username = document.getElementById('assignUsername').value.trim();
        if (!count || count < 1) {
          alert('請輸入正確數量');
          return;
        }
        generateBtn.disabled = true;
        try {
          const result = await apiRequest(`/api/admin/raffles/${raffleId}/generate-codes`, {
            method: 'POST',
            body: JSON.stringify({ count, username })
          });
          alert(`成功生成 ${result.count} 個驗證碼`);
          await loadCodes();
        } catch (err) {
          alert(err.message);
        } finally {
          generateBtn.disabled = false;
        }
      });

      copyAllBtn.addEventListener('click', async () => {
        try {
          const result = await apiRequest(`/api/admin/raffles/${raffleId}/codes`);
          const codes = (result.codes || []).map(c => c.code).join('|');
          await navigator.clipboard.writeText(codes);
          alert('全部驗證碼已複製到剪貼板');
        } catch (err) {
          alert(err.message);
        }
      });

      loadCodes().catch(err => alert(err.message));
    });
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title>會員管理 - 管理後台</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="container">
      <div class="header-content">
        <a href="/" class="site-logo">
          <img src="/img/mirai-3.png" alt="TMA台灣分部-未來飛翔">
        </a>
        <div class="header-text">
          <a href="/admin" class="back-link">← 返回後台</a>
          <h1>會員管理</h1>
          <p>管理會員資料與重置密碼</p>
        </div>
        <div class="header-buttons">
          <a href="/logout" class="btn btn-secondary btn-sm">登出</a>
        </div>
      </div>
    </div>
  </header>

  <main class="container">
    <section class="card">
      <div class="form-row">
        <div class="form-group">
          <label for="userSearch">搜尋會員用戶名</label>
          <input type="text" id="userSearch" placeholder="輸入用戶名關鍵字">
        </div>
        <div class="form-group" style="display:flex; align-items:flex-end;">
          <button id="searchBtn" class="btn btn-primary">搜尋</button>
        </div>
      </div>
      <div id="usersTable" class="admin-table-wrapper" style="margin-top: 16px;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>用戶名</th>
              <th>聯絡方式</th>
              <th>抽獎記錄</th>
              <th>已分配驗證碼</th>
              <th>已使用驗證碼</th>
              <th>建立時間</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody id="usersTbody"></tbody>
        </table>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> Ichiban Kuji Raffle System</p>
      <p style="margin-top: 8px; opacity: 0.7;">Powered by TMA台灣分部-未來飛翔</p>
    </div>
  </footer>

  <script src="/js/app.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      initAdminUsersPage();
    });
  </script>
</body>
</html>
